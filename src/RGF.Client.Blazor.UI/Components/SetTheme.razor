<RgfComboBox TValue="string" CssClass="d-inline-block" Width="auto" @bind-Value="Size" OnValueChanging="OnSizeChange" DataSource="_sizes" />
<RgfComboBox TValue="string" CssClass="d-inline-block" Width="auto" @bind-Value="ThemeName" OnValueChanging="OnThemeChange" DataSource="Themes" />

@inject IJSRuntime _jsRuntime
@code {

    [Parameter]
    public string ThemeName { get; set; } = "light";

    [Parameter]
    public string Size { get; set; } = "";

    private Dictionary<string, string> Themes = new() {
        { "light", "Light" },
        { "dark", "Dark" }
    };

    private Dictionary<string, string> _sizes = new() {
        { "", "default" },
        { "small", "small" }
    };

    private bool _settingsInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_settingsInitialized)
        {
            return;
        }

        try
        {
            var settings = await _jsRuntime.InvokeAsync<ThemeSettings>(RGFClientBlazorUIConfiguration.JsBlazorUiNamespace + ".SetTheme.getSettings", Themes.Keys.ToArray(), _sizes.Keys.ToArray());

            ThemeName = Themes.ContainsKey(settings.ThemeName) ? settings.ThemeName : Themes.Keys.First();
            Size = _sizes.ContainsKey(settings.Size) ? settings.Size : _sizes.Keys.First();

            _settingsInitialized = true;
            StateHasChanged();
        }
        catch (InvalidOperationException) { }
        catch (JSDisconnectedException) { }
    }

    private Task OnThemeChange(ChangeEventArgs<string> args) =>
        _jsRuntime.InvokeVoidAsync(RGFClientBlazorUIConfiguration.JsBlazorUiNamespace + ".SetTheme.setTheme", args.NewValue ?? string.Empty).AsTask();

    private Task OnSizeChange(ChangeEventArgs<string> args) =>
        _jsRuntime.InvokeVoidAsync(RGFClientBlazorUIConfiguration.JsBlazorUiNamespace + ".SetTheme.setSize", args.OldValue ?? string.Empty, args.NewValue ?? string.Empty).AsTask();

    private sealed class ThemeSettings
    {
        public string ThemeName { get; set; } = string.Empty;

        public string Size { get; set; } = string.Empty;
    }
}
